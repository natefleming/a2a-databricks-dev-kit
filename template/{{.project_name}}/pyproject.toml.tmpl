[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{.project_name}}"
version = "0.1.0"
description = "{{.agent_description}}"
readme = "README.md"
requires-python = ">=3.11"

dependencies = [
    "a2a-databricks-dev-kit @ git+https://github.com/natefleming/a2a-databricks-dev-kit.git@main",
    "a2a-sdk>=1.0,<1.1",
    "fastapi>=0.115,<0.120",
    "uvicorn[standard]>=0.30,<0.40",
    "pydantic>=2.7,<3",
    "pydantic-settings>=2.4,<3",
    "httpx>=0.27,<1",
    "sse-starlette>=2.1,<3",
    "databricks-sdk>=0.32,<1",
    "mlflow[databricks]>=2.17.0,<3",
    "databricks-langchain>=0.4,<1",
    "langchain-openai>=0.2,<1",
]

[dependency-groups]
dev = [
    "ruff>=0.6,<1",
    "pytest>=8,<9",
    "pytest-asyncio>=0.24,<1",
]

[tool.hatch.metadata]
# Required because requirements.txt + pyproject.toml reference the kit via
# `git+https://...`. Apps installs from requirements.txt at deploy time.
allow-direct-references = true

[tool.hatch.build.targets.wheel]
packages = ["src/app"]
sources = ["src"]
