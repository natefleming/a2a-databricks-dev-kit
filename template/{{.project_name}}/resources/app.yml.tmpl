resources:
  apps:
    a2a_agent_app:
      name: "${var.agent_name}-${bundle.target}"
      description: "${var.agent_description}"
      source_code_path: "../."
      permissions:
        - level: CAN_USE
          group_name: "users"
      user_api_scopes:
        - "serving.serving-endpoints"
      # Auto-permissioned resources for the App SP at deploy time.
      # Without these the App boots fine but runtime calls 403.
      resources:
        - name: chat-llm
          description: "LLM serving endpoint backing the agent."
          serving_endpoint:
            name: "${var.llm_endpoint}"
            permission: CAN_QUERY
{{- if eq .auth_mode "bearer"}}
        # Set var.bearer_secret_scope and var.bearer_secret_key (in databricks.yml
        # or per-target) to a Databricks secret you've already provisioned.
        - name: bearer-token
          description: "Inbound A2A bearer token, read at startup."
          secret:
            scope: "${var.bearer_secret_scope}"
            key: "${var.bearer_secret_key}"
            permission: READ
{{- end}}

  experiments:
    a2a_agent_experiment:
      # Per-user path because /Shared/a2a-agents/... requires the parent
      # directory to pre-exist and many workspaces don't grant CREATE there.
      name: "/Users/${workspace.current_user.userName}/a2a-agents-${var.agent_name}-${bundle.target}"

  # UC schema creation is opt-in. The reference agent doesn't use UC, and most
  # workspaces don't grant CREATE SCHEMA to ordinary users. To enable, uncomment:
  #
  # schemas:
  #   a2a_agent_schema:
  #     catalog_name: "${var.catalog}"
  #     name: "${var.schema}"
  #     grants:
  #       - principal: "${resources.apps.a2a_agent_app.service_principal_client_id}"
  #         privileges:
  #           - USE_SCHEMA
  #           - SELECT
  #           - EXECUTE
