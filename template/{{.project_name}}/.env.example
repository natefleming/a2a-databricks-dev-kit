# {{.project_name}} — local development env
# Copy to .env.local. Never commit .env.local.

A2A_AGENT_NAME={{.project_name}}
A2A_AGENT_DESCRIPTION={{.agent_description}}
A2A_AGENT_VERSION=0.1.0
A2A_LLM_ENDPOINT={{.llm_endpoint}}
A2A_LLM_AI_GATEWAY=false
A2A_AUTH_MODE={{.auth_mode}}
A2A_ENV=dev
A2A_CATALOG={{.catalog_name}}
A2A_SCHEMA={{.schema_name}}
A2A_BEARER_SECRET_SCOPE=
A2A_BEARER_SECRET_KEY=
A2A_OAUTH_AUDIENCE=
A2A_OAUTH_ISSUER=

A2A_CAPABILITY_STREAMING=true
A2A_CAPABILITY_PUSH_NOTIFICATIONS=false

# Used only by notebooks/register_in_gemini.py
GEMINI_PROJECT_ID=
GEMINI_LOCATION=global
GEMINI_APP_ID=
GEMINI_ASSISTANT_ID=default_assistant
GEMINI_COLLECTION=default_collection
