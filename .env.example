# a2a-databricks-dev-kit — local development environment
# Copy to .env.local and fill in. Never commit .env.local.

# --- Agent identity ---
A2A_AGENT_NAME=my-a2a-agent
A2A_AGENT_DESCRIPTION=An A2A-protocol agent running on Databricks
A2A_AGENT_VERSION=0.1.0

# --- LLM backing the agent ---
# Databricks Model Serving endpoint name, OR a serving endpoint exposed via AI Gateway.
A2A_LLM_ENDPOINT=databricks-claude-sonnet-4-6
# Set to "true" to route through /ai-gateway/mlflow/v1/chat/completions
A2A_LLM_AI_GATEWAY=false

# --- Inbound auth on the A2A endpoint ---
# bearer | oauth_m2m | none   (none is rejected when A2A_ENV=prod)
A2A_AUTH_MODE=bearer
A2A_ENV=dev
# When A2A_AUTH_MODE=bearer, the bearer token is read from Databricks secrets at startup.
A2A_BEARER_SECRET_SCOPE=
A2A_BEARER_SECRET_KEY=
# When A2A_AUTH_MODE=oauth_m2m, set the audience + issuer the agent will accept.
A2A_OAUTH_AUDIENCE=
A2A_OAUTH_ISSUER=

# --- Unity Catalog target for any agent artifacts ---
A2A_CATALOG=main
A2A_SCHEMA=a2a_agents

# --- Databricks workspace (only needed for local dev calling a workspace) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# --- A2A capabilities advertised in the Agent Card ---
A2A_CAPABILITY_STREAMING=true
A2A_CAPABILITY_PUSH_NOTIFICATIONS=false

# --- Gemini Enterprise registration (used by notebooks/register_in_gemini.py) ---
GEMINI_PROJECT_ID=
GEMINI_LOCATION=global
GEMINI_APP_ID=
GEMINI_ASSISTANT_ID=default_assistant
GEMINI_COLLECTION=default_collection
